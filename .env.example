# MailTag Email Classification - Environment Variables Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# REQUIRED: Email Account Configuration
# =============================================================================

# IMAP Configuration (for IMAP provider)
IMAP_USER=your-email@example.com
IMAP_PASSWORD=your-imap-password

# Gmail Configuration (for Gmail provider)
# Note: OAuth credentials are configured in credentials.json and token.json
# No environment variables needed for Gmail

# =============================================================================
# REQUIRED: AI Model Configuration
# =============================================================================

# Choose ONE of the following model providers:

# ---- OPTION 1: Ollama (Local AI) ----
# Ollama API URL (for local AI model)
OLLAMA_API_URL=http://localhost:11434

# Model to use (requires ollama_chat/ prefix for litellm)
# Examples: ollama_chat/gemma3n, ollama_chat/llama3.1, ollama_chat/qwen3-vl:8b-instruct
MODEL=ollama_chat/gemma3n
MODEL_NAME=ollama_chat/gemma3n

# Ollama Performance Settings (use when starting: OLLAMA_FLASH_ATTENTION=1 OLLAMA_KV_CACHE_TYPE=q4_0 OLLAMA_NUM_CTX=8192 ollama serve)
# OLLAMA_FLASH_ATTENTION=1
# OLLAMA_KV_CACHE_TYPE=q4_0
# OLLAMA_NUM_CTX=8192

# ---- OPTION 2: Google Gemini (Cloud AI) ----
# Get your API key from: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key
# MODEL=gemini/gemini-2.5-flash
# MODEL_NAME=gemini/gemini-2.5-flash
# API_BASE=  # Leave empty for Gemini (not needed)

# Other Gemini models available:
# - gemini/gemini-2.5-flash (recommended - latest, fastest)
# - gemini/gemini-2.5-flash-preview-09-2025
# - gemini/gemini-2.5-flash-lite-preview-09-2025 (cheaper, lighter)
# - gemini/gemini-1.5-flash
# - gemini/gemini-1.5-pro

# ---- OPTION 3: OpenRouter (Multi-provider Cloud) ----
# OPENROUTER_API_KEY=your-openrouter-api-key
# MODEL=openai/gpt-4o-mini
# API_BASE=https://openrouter.ai/api/v1

# =============================================================================
# OPTIONAL: Advanced Configuration
# =============================================================================

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# Disable telemetry (if using CrewAI or similar tools)
# CREWAI_DISABLE_TELEMETRY=true
# OTEL_SDK_DISABLED=true

# LiteLLM timeout in seconds
# LITELLM_TIMEOUT=300

# =============================================================================
# Development & Testing
# =============================================================================

# Email address for testing
# MAIL=test@example.com

# =============================================================================
# NOTES
# =============================================================================
#
# 1. Never commit .env to version control (already in .gitignore)
# 2. For IMAP: Use app-specific passwords for Gmail/Outlook if 2FA is enabled
# 3. For Gmail: Follow OAuth setup in docs to generate credentials.json
# 4. Ollama must be running locally: ollama serve
# 5. See CLAUDE.md for detailed setup instructions
